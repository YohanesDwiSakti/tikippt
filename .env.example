# Copy to .env and fill in. Never commit .env.
NODE_ENV=development

# ── Server (apps/server) ──────────────────────────────────
PORT=3000

# ── Supabase: database + auth + storage ───────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client or prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection (migrations / server-side queries)
DATABASE_URL=

# ── Web (apps/web) ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
# Public URL of the web app (web dev server; server uses PORT above).
# Used as the redirectTo for OAuth (Google, GitHub) and password-reset emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ── AI models (only when the project uses large models) ───
# Large models run on Hugging Face (Inference API / Endpoints), called from apps/server.
# HUGGINGFACE_API_KEY=

# ── Payments: Midtrans (only when the project takes payments) ──
# Dashboard → Settings → Access Keys. Server key is server-only, never NEXT_PUBLIC_.
# MIDTRANS_SERVER_KEY=
# NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
# MIDTRANS_IS_PRODUCTION=false
